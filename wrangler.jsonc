// Sean-Claude Van Damme's General Store — Worker configuration.
// Deploys to the scvd.store custom domain via Git-connected builds.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "scvd-general-store",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    { "pattern": "scvd.store", "custom_domain": true }
  ],
  // Weekly digest: Sundays 7am ET (11:00 UTC during daylight time).
  // Hourly: the phantom-check walk (due out-of-band probes).
  "triggers": {
    "crons": ["0 11 * * SUN", "30 * * * *"]
  },
  // KV namespaces. Create them once with:
  //   wrangler kv namespace create ORDERS
  //   wrangler kv namespace create GUESTBOOK
  //   wrangler kv namespace create COUNTERS
  //   wrangler kv namespace create PATRONS
  // then paste the ids below.
  "kv_namespaces": [
    { "binding": "ORDERS", "id": "4a23f9dd93f4434aad98295e592c8805" },
    { "binding": "GUESTBOOK", "id": "93c5a5a59fbe4fa6ad96ed9af3852d70" },
    { "binding": "COUNTERS", "id": "bc1397211dbd4b30876edb76b45a1142" },
    { "binding": "PATRONS", "id": "b3b7dc0f951f4b4a9995afe7dc35e015" }
  ],
  "vars": {
    "STORE_BASE_URL": "https://scvd.store"
  }
  // Secrets (never in this file — set via `wrangler secret put <NAME>`):
  //   PAY_TO_ADDRESS      Base wallet that receives USDC
  //   CDP_API_KEY_ID      Coinbase Developer Platform key id (facilitator auth)
  //   CDP_API_KEY_SECRET  Coinbase Developer Platform key secret
  //   SIGNING_KEY         ed25519 private key seed, 64 hex chars (npm run keys:generate)
  //   ADMIN_PASSWORD      Basic Auth password for /admin
}
